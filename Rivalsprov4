-- Cached RaycastParams
local wallRayParams = RaycastParams.new()
wallRayParams.FilterType = Enum.RaycastFilterType.Exclude

-- Get closest target (Rage forces Head)
local function GetPartToFov(Part)
    local candidates = {}
    local screenCenter = mousePPos
    local char = lp.Character
    if not char then return nil end

    wallRayParams.FilterDescendantsInstances = {char}

    for _, v in ipairs(pl:GetPlayers()) do
        if #candidates >= 8 then break end
        if v ~= lp and v.Character then
            local usePart = rageEnabled and "Head" or Part  -- Rage = forced headshots
            if not v.Character:FindFirstChild(usePart) then continue end
            
            if FullSettings.AimBot.Checks.AliveCheck and v.Character:FindFirstChildOfClass("Humanoid") and v.Character.Humanoid.Health <= 0 then continue end
            
            local targetPos = v.Character[usePart].Position
            local vPos, onScreen = camera:WorldToViewportPoint(targetPos)
            if not onScreen or vPos.Z <= 0 then continue end
            
            local distance = (Vector2.new(vPos.X, vPos.Y) - screenCenter).Magnitude
            if FullSettings.AimBot.Fov.Enable and distance > FullSettings.AimBot.Fov.Size then continue end
            
            table.insert(candidates, {player = v, dist = distance, pos = targetPos})
        end
    end
    
    table.sort(candidates, function(a, b) return a.dist < b.dist end)
    
    for _, cand in ipairs(candidates) do
        local v = cand.player
        if FullSettings.AimBot.Checks.TeamCheck and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.HumanoidRootPart:FindFirstChild("TeammateLabel") then continue end
        
        if FullSettings.AimBot.Checks.WallCheck then
            local result = workspace:Raycast(camera.CFrame.Position, (cand.pos - camera.CFrame.Position).Unit * 1000, wallRayParams)
            if not result or not result.Instance:IsDescendantOf(v.Character) then continue end
        end
        return v
    end
    return nil
end

