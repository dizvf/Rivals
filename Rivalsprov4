local OriginalStats = {}
local clientItemModule = nil

local function safeRequire()
    pcall(function()
        clientItemModule = require(localPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem)
    end)
end
safeRequire()

if clientItemModule then
    local inputFunc = clientItemModule.Input
    local oldInput = hookfunction(inputFunc, function(...)
        local args = {...}
        if type(args[1]) == "table" and args[1].Info then
            local gunName = args[1].Name or "Unknown"
            if not OriginalStats[gunName] then
                OriginalStats[gunName] = table.clone(args[1].Info)
            end
            if getgenv().RapidFireEnabled then
                local info = args[1].Info
                info.ShootRecoil = 0
                info.ShootSpread = 0
                info.ProjectileSpeed = 99999999
                info.ShootCooldown = 0.001
                info.QuickShotCooldown = -1
                info.ShootBurstCooldown = -1
                info.ReloadTime = 0.05
            else
                for k, v in pairs(OriginalStats[gunName]) do
                    if args[1].Info[k] then args[1].Info[k] = v end
                end
            end
        end
        return oldInput(...)
    end)
end

