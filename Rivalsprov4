-- Pre-create ESP for existing + new players (zero lag creation)
local function createESP(player)
    if player == lp then return end
    local function setupChar(char)
        if char:FindFirstChild("Esp") then return end
        local Esp = Instance.new("Highlight")
        Esp.RobloxLocked = true
        Esp.Name = "Esp"
        Esp.Adornee = char
        Esp.Parent = char
    end
    if player.Character then setupChar(player.Character) end
    player.CharacterAdded:Connect(setupChar)
end

for _, player in ipairs(pl:GetPlayers()) do createESP(player) end
pl.PlayerAdded:Connect(createESP)

