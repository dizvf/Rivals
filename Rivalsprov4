local ijConnection = nil
local function toggleInfiniteJump(state)
    if state then
        if not ijConnection then
            ijConnection = UIS.JumpRequest:Connect(function()
                local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
            end)
        end
    else
        if ijConnection then ijConnection:Disconnect() ijConnection = nil end
    end
end

-- Speed Hack
local speedValue = 16
local speedConnection = nil
local function applySpeed()
    local hum = lp.Character and lp.Character:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = speedValue
        if not speedConnection then
            speedConnection = lp.CharacterAdded:Connect(function(char)
                local h = char:WaitForChild("Humanoid")
                h.WalkSpeed = speedValue
                h:GetPropertyChangedSignal("WalkSpeed"):Connect(function() h.WalkSpeed = speedValue end)
            end)
        end
    end
end

-- Big Heads (event-based, no loops - fixed your resizeHeads)
local bigHeadsEnabled = false
local originalSizes = {}
local function applyBigHead(char)
    if not bigHeadsEnabled then return end
    local head = char:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        if not originalSizes[head] then originalSizes[head] = head.Size end
        head.Size = Vector3.new(5, 5, 5)
        head.CanCollide = false
    end
end
local function setupBigHeads(player)
    if player == lp then return end
    local function onChar(char)
        applyBigHead(char)
    end
    if player.Character then onChar(player.Character) end
    player.CharacterAdded:Connect(onChar)
end
for _, p in ipairs(pl:GetPlayers()) do setupBigHeads(p) end
pl.PlayerAdded:Connect(setupBigHeads)

