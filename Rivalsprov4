-- ====================== SILENT AIM (Built-in - no external load) ======================
local silentAimEnabled = false
local aimAtHeadSilent = true  -- true = Head, false = HumanoidRootPart

local function getClosestScreenTarget()
    local closest = nil
    local shortestDist = math.huge
    local mousePos = Vector2.new(UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end

        local targetChar = player.Character
        local targetPart = targetChar:FindFirstChild(aimAtHeadSilent and "Head" or "HumanoidRootPart")
        if not targetPart then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
        if dist < shortestDist then
            shortestDist = dist
            closest = targetPart
        end
    end
    return closest
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if silentAimEnabled and method == "Raycast" then
        local callingScript = getcallingscript()
        local scriptName = tostring(callingScript)

        if scriptName == "Equipment" or 
           scriptName == "FighterController" or 
           scriptName == "PlayerDataController" or 
           scriptName == "ControlsController" then
            
            local target = getClosestScreenTarget()
            if target then
                args[2] = Camera.CFrame.Position                    -- Origin
                args[3] = (target.Position - args[2]).Unit * 1000   -- Direction
            end
        end
    end

    return oldNamecall(self, unpack(args))
end)

-- ====================== VISIBLE AIMBOT ======================
local visibleAimbotEnabled = false
local fovLimit = 150
local teamCheckEnabled = false
local wallCheckEnabled = false

local function getClosestVisibleTarget()
    local shortest = math.huge
    local nearest = nil
    local localRoot = character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end

        local targetChar = player.Character
        local targetPart = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetPart then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then continue end

        local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
        if mouseDist > fovLimit then continue end

        if wallCheckEnabled then
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {character}
            params.FilterType = Enum.RaycastFilterType.Blacklist
            local result = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 1000, params)
            if not result or not result.Instance:IsDescendantOf(targetChar) then continue end
        end

        local dist = (targetPart.Position - localRoot.Position).Magnitude
        if dist < shortest then
            shortest = dist
            nearest = targetChar
        end
    end
    return nearest
end

local aimbotConnection
local function toggleVisibleAimbot(state)
    if aimbotConnection then aimbotConnection:Disconnect() end
    if not state then return end

    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not visibleAimbotEnabled then return end
        local target = getClosestVisibleTarget()
        if target and target:FindFirstChild("HumanoidRootPart") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.HumanoidRootPart.Position)
        end
    end)
end

