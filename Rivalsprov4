-- ==================== CHEAT LOGIC (FLAGS + HOOKS) ====================
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local OriginalStats = {}
local clientItemModule = nil
local flyVelocity = nil
local speedConnection = nil
local triggerConnection = nil

-- Safe module load
local function safeRequire()
    local success, module = pcall(function()
        return require(LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem)
    end)
    if success and module then
        clientItemModule = module
        return true
    end
    return false
end

-- Main Input Hook (Rapid Fire + Aim)
if safeRequire() then
    local inputFunc = clientItemModule.Input
    local oldInput = hookfunction(inputFunc, function(...)
        local args = {...}
        
        if type(args[1]) == "table" and args[1].Info then
            local gunName = args[1].Name or "UnknownGun"
            
            -- Save originals once
            if not OriginalStats[gunName] then
                OriginalStats[gunName] = {
                    ShootRecoil = args[1].Info.ShootRecoil,
                    ShootSpread = args[1].Info.ShootSpread,
                    ProjectileSpeed = args[1].Info.ProjectileSpeed,
                    ShootCooldown = args[1].Info.ShootCooldown,
                    QuickShotCooldown = args[1].Info.QuickShotCooldown,
                    ShootBurstCooldown = args[1].Info.ShootBurstCooldown or 0,
                    ReloadTime = args[1].Info.ReloadTime or 1,
                }
            end
            
            -- RAPID FIRE (if toggled)
            if getgenv().RapidFireEnabled then
                local info = args[1].Info
                info.ShootRecoil = 0
                info.ShootSpread = 0
                info.ProjectileSpeed = 99999999
                info.ShootCooldown = 0.001
                info.QuickShotCooldown = -1
                info.ShootBurstCooldown = -1
                info.ReloadTime = 0.05
            else
                local orig = OriginalStats[gunName]
                if orig then
                    for k, v in pairs(orig) do
                        if args[1].Info[k] ~= nil then
                            args[1].Info[k] = v
                        end
                    end
                end
            end
            
            -- AIM REDIRECTION (Silent or Ragebot)
            local useRage = getgenv().RagebotEnabled
            local fov = useRage and 350 or 95
            local hitChance = useRage and 100 or 82
            local headChance = useRage and 95 or 25
            local humanize = useRage and 0 or 0.6
            
            if (getgenv().SilentAimEnabled or getgenv().RagebotEnabled) and math.random(1, 100) <= hitChance then
                local targetChar = nil
                local closestDist = math.huge
                
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Team ~= LocalPlayer.Team then
                        local root = plr.Character.HumanoidRootPart
                        local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                        if onScreen then
                            local mousePos = UserInputService:GetMouseLocation()
                            local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            if mouseDist < fov and mouseDist < closestDist then
                                closestDist = mouseDist
                                targetChar = plr.Character
                            end
                        end
                    end
                end
                
                if targetChar then
                    local rand = math.random(1, 100)
                    local hitPartName = (rand <= headChance) and "Head" or "UpperTorso"
                    local hitPart = targetChar:FindFirstChild(hitPartName) or targetChar:FindFirstChild("Head")
                    if hitPart then
                        local offset = Vector3.new(
                            math.random(-10, 10) * humanize / 10,
                            math.random(-5, 5) * humanize / 10,
                            math.random(-10, 10) * humanize / 10
                        )
                        local targetPos = hitPart.Position + offset
                        local shooterPos = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position) or Vector3.new()
                        local direction = (targetPos - shooterPos).Unit
                        
                        if args[1].Info then
                            if args[1].Info.Direction then args[1].Info.Direction = direction
                            elseif args[1].Info.ShootDirection then args[1].Info.ShootDirection = direction
                            elseif args[1].Info.TargetPosition then args[1].Info.TargetPosition = targetPos
                            end
                        elseif args[1].Direction then
                            args[1].Direction = direction
                        end
                    end
                end
            end
        end
        return oldInput(...)
    end)
end

-- ==================== TRIGGERBOT ====================
triggerConnection = RunService.RenderStepped:Connect(function()
    if not getgenv().TriggerBotEnabled then return end
    local mouse = LocalPlayer:GetMouse()
    local target = mouse.Target
    if target and target.Parent then
        local char = target.Parent
        if char:FindFirstChild("Humanoid") and char ~= LocalPlayer.Character then
            local enemyPlr = Players:GetPlayerFromCharacter(char)
            if enemyPlr and enemyPlr.Team ~= LocalPlayer.Team then
                VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 1)
                task.wait(0.008)
                VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 1)
            end
        end
    end
end)

-- ==================== FLYING ====================
local function updateFlying()
    if getgenv().FlyingEnabled then
        if not flyVelocity and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            flyVelocity = Instance.new("BodyVelocity")
            flyVelocity.MaxForce = Vector3.new(4000, 4000, 4000)
            flyVelocity.Velocity = Vector3.new(0, 0, 0)
            flyVelocity.Parent = LocalPlayer.Character.HumanoidRootPart
        end
        if flyVelocity then
            local moveDir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
            flyVelocity.Velocity = moveDir.Unit * 100
        end
    elseif flyVelocity then
        flyVelocity:Destroy()
        flyVelocity = nil
    end
end

RunService.Heartbeat:Connect(updateFlying)

-- ==================== SPEED HACK ====================
local function updateSpeedHack()
    if not getgenv().SpeedHackEnabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = LocalPlayer.Character.HumanoidRootPart
    local moveDir = Vector3.new()
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= Camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += Camera.CFrame.RightVector end
    if moveDir.Magnitude > 0 then
        root.CFrame = root.CFrame + (moveDir.Unit * 1.5)
    end
end

speedConnection = RunService.Heartbeat:Connect(updateSpeedHack)

