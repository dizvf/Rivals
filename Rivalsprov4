local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
LocalPlayer.CharacterAdded:Connect(function(new) character = new end)

-- ====================== FIXED SILENT AIM ======================
local silentAimEnabled = false
local silentAimHead = true
local silentTeamCheck = true
local silentWallbang = true
local silentFOV = 180

local function getClosestSilentTarget()
    if not silentAimEnabled then return nil end

    local closest = nil
    local shortest = math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        if silentTeamCheck and player.Team == LocalPlayer.Team then continue end

        local targetChar = player.Character
        local targetPart = targetChar:FindFirstChild(silentAimHead and "Head" or "HumanoidRootPart")
        if not targetPart then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen or screenPos.Z < 0 then continue end

        local center = Camera.ViewportSize / 2
        local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if distToCenter > silentFOV then continue end

        if not silentWallbang then
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {character}
            params.FilterType = Enum.RaycastFilterType.Blacklist
            local result = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 2000, params)
            if not result or not result.Instance:IsDescendantOf(targetChar) then continue end
        end

        local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
        if mouseDist < shortest then
            shortest = mouseDist
            closest = targetPart
        end
    end
    return closest
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if silentAimEnabled and method == "Raycast" then
        local callingScript = getcallingscript()
        local name = tostring(callingScript)

        if name == "Equipment" or name == "FighterController" or 
           name == "PlayerDataController" or name == "ControlsController" or
           name:find("Gun") or name:find("Weapon") then

            local target = getClosestSilentTarget()
            if target then
                args[2] = Camera.CFrame.Position
                args[3] = (target.Position - args[2]).Unit * 2000
            end
        end
    end

    return oldNamecall(self, unpack(args))
end)

-- ====================== VISIBLE AIMBOT ======================
local visibleAimbotEnabled = false
local visibleFOV = 150
local visibleTeamCheck = true
local visibleWallCheck = false

local function getClosestVisibleTarget()
    local shortest = math.huge
    local nearest = nil
    local localRoot = character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        if visibleTeamCheck and player.Team == LocalPlayer.Team then continue end

        local targetChar = player.Character
        local targetPart = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetPart then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then continue end

        local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - Camera.ViewportSize/2).Magnitude
        if mouseDist > visibleFOV then continue end

        if visibleWallCheck then
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {character}
            params.FilterType = Enum.RaycastFilterType.Blacklist
            local result = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 2000, params)
            if not result or not result.Instance:IsDescendantOf(targetChar) then continue end
        end

        local dist = (targetPart.Position - localRoot.Position).Magnitude
        if dist < shortest then
            shortest = dist
            nearest = targetChar
        end
    end
    return nearest
end

local aimbotConnection
local function toggleVisibleAimbot(state)
    if aimbotConnection then aimbotConnection:Disconnect() aimbotConnection = nil end
    if not state then return end
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not visibleAimbotEnabled then return end
        local target = getClosestVisibleTarget()
        if target and target:FindFirstChild("HumanoidRootPart") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.HumanoidRootPart.Position)
        end
    end)
end

